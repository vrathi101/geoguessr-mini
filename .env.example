# GeoGuessr Mini — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Google Maps JavaScript API key
# Enable these APIs in Google Cloud Console:
#   - Maps JavaScript API
#   - Street View Static API
# Restrict the key to your domain for production.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Supabase (required for leaderboard + Google Auth)
# Create a free project at https://supabase.com
# Find these in: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
